PORT=5001
NODE_ENV=production

# Database Configuration (Production)
# Railway/Render will provide DATABASE_URL, or use individual vars
DATABASE_URL=postgresql://user:password@host:5432/database
DB_USER=postgres
DB_HOST=your-production-db-host
DB_NAME=shura
DB_PASSWORD=your-production-db-password
DB_PORT=5432

# JWT Secret (CHANGE THIS - use a strong random string)
JWT_SECRET=CHANGE_THIS_TO_STRONG_RANDOM_STRING_FOR_PRODUCTION

# Cloudinary Configuration (for image uploads)
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_FOLDER=shura/uploads

# Email Configuration (Gmail)
EMAIL_USER=shuraa.life@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
ADMIN_EMAIL=shuraa.life@gmail.com

# Frontend URL (Production)
FRONTEND_URL=https://your-production-domain.vercel.app

# Razorpay Configuration (Production)
# Apply for live keys AFTER deployment at https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_live_your_production_key
RAZORPAY_KEY_SECRET=your_production_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_from_razorpay_dashboard

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=https://your-production-domain.vercel.app,https://www.your-domain.com

# Azure Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...;ApplicationId=...

# Cookie/session configuration
# Use none when frontend and backend are on different HTTPS sites (for example Vercel + Railway).
COOKIE_SAME_SITE=none
